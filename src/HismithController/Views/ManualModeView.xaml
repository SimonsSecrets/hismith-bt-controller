<UserControl x:Class="HismithController.Views.ManualModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HismithController.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:ManualModeViewModel}"
             mc:Ignorable="d">

    <StackPanel>

        <!-- ========== HEADER ========== -->
        <TextBlock Text="Speed control"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" />
        <TextBlock Text="Set the target — the device ramps smoothly to it."
                   FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                   Margin="0,2,0,18" />

        <!-- ========== HERO READOUT ========== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Percent field -->
            <Border Grid.Column="0" CornerRadius="10" BorderThickness="1" Padding="18,14">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
                        <Style.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource RoseBrush}" />
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter Property="BorderThickness" Value="2" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <!-- Pulse overlay -->
                    <Border CornerRadius="8" Background="{DynamicResource RoseSoftBrush}"
                            IsHitTestVisible="False" Opacity="0" Margin="-18,-14">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTargetReached}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0" Duration="0:0:1.1" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <!-- Content -->
                    <StackPanel>
                        <TextBox x:Name="PercentField"
                                 Text="{Binding PercentFieldText, UpdateSourceTrigger=LostFocus}"
                                 FontSize="40" FontWeight="Light"
                                 Foreground="{DynamicResource TextBrush}"
                                 Background="Transparent" BorderThickness="0"
                                 TextAlignment="Center" CaretBrush="{DynamicResource RoseBrush}"
                                 SelectionBrush="{DynamicResource RoseSoftBrush}"
                                 Padding="0" KeyDown="OnPercentFieldKeyDown"
                                 GotKeyboardFocus="OnPercentFieldGotFocus"
                                 LostKeyboardFocus="OnPercentFieldLostFocus"
                                 PreviewMouseLeftButtonDown="OnNumFieldPreviewMouseLeftButtonDown" />
                        <TextBlock Text="SPEED (%)"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- BPM field -->
            <Border Grid.Column="2" CornerRadius="10" BorderThickness="1" Padding="18,14">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
                        <Style.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource RoseBrush}" />
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter Property="BorderThickness" Value="2" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <!-- Pulse overlay -->
                    <Border CornerRadius="8" Background="{DynamicResource RoseSoftBrush}"
                            IsHitTestVisible="False" Opacity="0" Margin="-18,-14">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTargetReached}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0" Duration="0:0:1.1" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <!-- Content -->
                    <StackPanel>
                        <TextBox x:Name="BpmField"
                                 Text="{Binding BpmFieldText, UpdateSourceTrigger=LostFocus}"
                                 FontSize="40" FontWeight="Light"
                                 Foreground="{DynamicResource TextBrush}"
                                 Background="Transparent" BorderThickness="0"
                                 TextAlignment="Center" CaretBrush="{DynamicResource RoseBrush}"
                                 SelectionBrush="{DynamicResource RoseSoftBrush}"
                                 Padding="0" KeyDown="OnBpmFieldKeyDown"
                                 GotKeyboardFocus="OnBpmFieldGotFocus"
                                 LostKeyboardFocus="OnBpmFieldLostFocus"
                                 PreviewMouseLeftButtonDown="OnNumFieldPreviewMouseLeftButtonDown" />
                        <TextBlock Text="TEMPO (BPM)"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== SLIDER ========== -->
        <Slider Minimum="0" Maximum="{Binding MaxBpm}"
                Value="{Binding DisplayedBpm, Mode=TwoWay}"
                Style="{StaticResource ManualSpeedSlider}"
                IsMoveToPointEnabled="True"
                Margin="0,20,0,0" Height="28"
                Thumb.DragStarted="OnSliderDragStarted"
                Thumb.DragCompleted="OnSliderDragCompleted" />

        <!-- ========== DIVIDER ========== -->
        <Border Height="1" Background="{DynamicResource AppBorderBrush}"
                Margin="0,22,0,18" />

        <!-- ========== PRESETS ========== -->
        <TextBlock Text="PRESETS" FontSize="12" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextDimBrush}"
                   Margin="0,0,0,10" />

        <ItemsControl ItemsSource="{Binding Presets}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding DataContext.SetPresetCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PresetChip}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource RoseTintBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource RoseBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" />
                            <TextBlock Text="{Binding Bpm, StringFormat='  ·  {0} BPM'}"
                                       FontSize="12.5"
                                       Foreground="{DynamicResource TextDimBrush}" />
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
</UserControl>
