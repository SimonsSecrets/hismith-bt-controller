<UserControl x:Class="HismithController.Controls.StatusChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HismithController.ViewModels"
             xmlns:conv="clr-namespace:HismithController.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:EnumToVisibilityConverter x:Key="EnumToVis" />
    </UserControl.Resources>

    <Grid>
        <!-- Chip button -->
        <Button x:Name="ChipButton" Cursor="Hand"
                Command="{Binding TogglePopoverCommand}">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ChipBorder"
                            Height="30" CornerRadius="15"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            Padding="10,0,8,0"
                            SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Status dot -->
                            <Ellipse x:Name="StatusDot" Width="8" Height="8"
                                     Fill="{DynamicResource TextFaintBrush}" Margin="0,0,6,0" />
                            <!-- Chevron down -->
                            <Path Data="M6 9 L12 15 L18 9"
                                  Stroke="{DynamicResource TextFaintBrush}" StrokeThickness="1.6"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Width="12" Height="12" Stretch="Uniform"
                                  Margin="2,0,0,0" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ChipBorder" Property="Background"
                                    Value="{DynamicResource SurfaceSoftBrush}" />
                            <Setter TargetName="ChipBorder" Property="BorderBrush"
                                    Value="{DynamicResource BorderStrongBrush}" />
                        </Trigger>
                        <DataTrigger Binding="{Binding ChipState}" Value="Scanning">
                            <Setter TargetName="StatusDot" Property="Fill"
                                    Value="{DynamicResource AmberBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ChipState}" Value="Connecting">
                            <Setter TargetName="StatusDot" Property="Fill"
                                    Value="{DynamicResource AmberBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ChipState}" Value="Connected">
                            <Setter TargetName="StatusDot" Property="Fill"
                                    Value="{DynamicResource SageBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ChipState}" Value="Demo">
                            <Setter TargetName="StatusDot" Property="Fill"
                                    Value="{DynamicResource AmberBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ChipState}" Value="Lost">
                            <Setter TargetName="StatusDot" Property="Fill"
                                    Value="{DynamicResource CoralBrush}" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Popover popup -->
        <Popup x:Name="PopoverPopup"
               PlacementTarget="{Binding ElementName=ChipButton}"
               Placement="Bottom" HorizontalOffset="-200" VerticalOffset="8"
               StaysOpen="False" AllowsTransparency="True"
               IsOpen="{Binding IsPopoverOpen, Mode=TwoWay}">
            <Grid Width="260">
                <!-- Shadow layer -->
                <Border CornerRadius="12" Background="{DynamicResource PopoverSurfaceBrush}" Margin="8">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" Direction="270" BlurRadius="20" Color="{DynamicResource PopoverShadowColor}" Opacity="0.14" />
                    </Border.Effect>
                </Border>
                <!-- Content layer -->
                <Border CornerRadius="12" Background="{DynamicResource PopoverSurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                        Padding="14" Margin="8" ClipToBounds="True">
                    <Grid>
                    <!-- ===== Demo-mode popover (design app.jsx StatusChip demo branch) ===== -->
                    <StackPanel Visibility="{Binding ChipState, Converter={StaticResource EnumToVis}, ConverterParameter=Demo}">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <!-- Amber rounded square with monitor glyph -->
                            <Border Width="36" Height="36" CornerRadius="10"
                                    Background="{DynamicResource AmberTintBrush}" Margin="0,0,10,0">
                                <Path Data="M3 4 H21 a1 1 0 0 1 1 1 V15 a1 1 0 0 1 -1 1 H3 a1 1 0 0 1 -1 -1 V5 a1 1 0 0 1 1 -1 M8 21 H16 M12 17 V21"
                                      Stroke="{DynamicResource AmberBrush}" StrokeThickness="1.7"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="18" Height="18" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Demo mode" FontWeight="SemiBold"
                                           FontSize="13.5" Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="No device connected" FontSize="11"
                                           Foreground="{DynamicResource TextDimBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0"
                                Padding="0,8,0,12">
                            <TextBlock Text="You're exploring offline — no signals are sent to any device."
                                       FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                                       TextWrapping="Wrap" LineHeight="17" />
                        </Border>

                        <Button Style="{DynamicResource PrimaryButton}"
                                Content="Connect a device"
                                Command="{Binding DisconnectCommand}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- ===== Connected popover ===== -->
                    <StackPanel Visibility="{Binding ChipState, Converter={StaticResource EnumToVis}, ConverterParameter=Connected}">
                        <!-- Device info header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" CornerRadius="10"
                                    Background="{DynamicResource RoseTintBrush}" Margin="0,0,10,0">
                                <Path Data="M7 7 L17 17 L12 22 V2 L17 7 L7 17"
                                      Stroke="{DynamicResource RoseBrush}" StrokeThickness="1.6"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="18" Height="18" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold"
                                           FontSize="13.5" Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="A4:C1:38:9F:21:E2" FontSize="11"
                                           Foreground="{DynamicResource TextDimBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Signal -->
                        <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0"
                                Padding="0,8,0,12">
                            <DockPanel>
                                <TextBlock Text="Signal" FontSize="12"
                                           Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                            VerticalAlignment="Center" Height="14">
                                    <Border Width="3" CornerRadius="1" Margin="0,0,2,0"
                                            VerticalAlignment="Bottom" Height="5"
                                            Background="{DynamicResource RoseBrush}" />
                                    <Border Width="3" CornerRadius="1" Margin="0,0,2,0"
                                            VerticalAlignment="Bottom" Height="9"
                                            Background="{DynamicResource RoseBrush}" />
                                    <Border Width="3" CornerRadius="1"
                                            VerticalAlignment="Bottom" Height="13"
                                            Background="{DynamicResource RoseBrush}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Disconnect button -->
                        <Button Style="{DynamicResource GhostButton}"
                                Content="Disconnect"
                                Command="{Binding DisconnectCommand}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Popup>
    </Grid>
</UserControl>
