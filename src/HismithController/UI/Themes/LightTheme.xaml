<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <!-- Background -->
    <Color x:Key="BackgroundColor">#FDF8F6</Color>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />

    <!-- Surface -->
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />

    <Color x:Key="SurfaceSoftColor">#FBF3F0</Color>
    <SolidColorBrush x:Key="SurfaceSoftBrush" Color="{StaticResource SurfaceSoftColor}" />

    <!-- Elevated surface for popovers: matches the white surface in light mode (the popup already
         separates from the off-white background via its shadow). See DarkTheme for the dark value. -->
    <Color x:Key="PopoverSurfaceColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="PopoverSurfaceBrush" Color="{StaticResource PopoverSurfaceColor}" />

    <!-- Slider thumb: white knob, matching the design (.slider thumb background #fff). -->
    <Color x:Key="SliderThumbColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="SliderThumbBrush" Color="{StaticResource SliderThumbColor}" />

    <!-- Visualizer background gradient (design viz-bg-top / viz-bg-bot tokens) -->
    <Color x:Key="VizBgTopColor">#FBEFF3</Color>
    <Color x:Key="VizBgBotColor">#FFF7F0</Color>
    <LinearGradientBrush x:Key="VizBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource VizBgTopColor}" Offset="0" />
        <GradientStop Color="{StaticResource VizBgBotColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- Borders -->
    <Color x:Key="BorderColor">#EFE3DE</Color>
    <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource BorderColor}" />

    <Color x:Key="BorderStrongColor">#E2D2CC</Color>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />

    <!-- Text -->
    <Color x:Key="TextColor">#2A1F1F</Color>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />

    <Color x:Key="TextDimColor">#8A7A78</Color>
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}" />

    <Color x:Key="TextFaintColor">#B6A7A4</Color>
    <SolidColorBrush x:Key="TextFaintBrush" Color="{StaticResource TextFaintColor}" />

    <!-- Rose (primary accent) -->
    <Color x:Key="RoseColor">#C4768A</Color>
    <SolidColorBrush x:Key="RoseBrush" Color="{StaticResource RoseColor}" />

    <Color x:Key="RoseHoverColor">#B26478</Color>
    <SolidColorBrush x:Key="RoseHoverBrush" Color="{StaticResource RoseHoverColor}" />

    <Color x:Key="RoseDarkColor">#9D5468</Color>
    <SolidColorBrush x:Key="RoseDarkBrush" Color="{StaticResource RoseDarkColor}" />

    <Color x:Key="RoseTintColor">#F6E5EA</Color>
    <SolidColorBrush x:Key="RoseTintBrush" Color="{StaticResource RoseTintColor}" />

    <Color x:Key="RoseSoftColor">#FBEFF3</Color>
    <SolidColorBrush x:Key="RoseSoftBrush" Color="{StaticResource RoseSoftColor}" />

    <!-- Gold -->
    <Color x:Key="GoldColor">#D4A96A</Color>
    <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource GoldColor}" />

    <Color x:Key="GoldTintColor">#F7EBD6</Color>
    <SolidColorBrush x:Key="GoldTintBrush" Color="{StaticResource GoldTintColor}" />

    <!-- Sage (success / connected) -->
    <Color x:Key="SageColor">#7FA688</Color>
    <SolidColorBrush x:Key="SageBrush" Color="{StaticResource SageColor}" />

    <Color x:Key="SageTintColor">#E1EDE3</Color>
    <SolidColorBrush x:Key="SageTintBrush" Color="{StaticResource SageTintColor}" />

    <!-- Coral (error) -->
    <Color x:Key="CoralColor">#D88C7B</Color>
    <SolidColorBrush x:Key="CoralBrush" Color="{StaticResource CoralColor}" />

    <Color x:Key="CoralTintColor">#F8E1DB</Color>
    <SolidColorBrush x:Key="CoralTintBrush" Color="{StaticResource CoralTintColor}" />

    <!-- Emergency-stop full-screen overlay backdrop (design .stop-overlay, light variant:
         radial circle at 50% 40%, rgba(209,75,61,0.46) → rgba(209,75,61,0.30)@50% → rgba(38,20,18,0.56)@100%).
         ARGB alpha = round(opacity*255): 0.46→#75, 0.30→#4C, 0.56→#8F. -->
    <RadialGradientBrush x:Key="StopOverlayBrush" GradientOrigin="0.5,0.4" Center="0.5,0.4"
                         RadiusX="1.0" RadiusY="1.0">
        <GradientStop Color="#75D14B3D" Offset="0" />
        <GradientStop Color="#4CD14B3D" Offset="0.5" />
        <GradientStop Color="#8F261412" Offset="1" />
    </RadialGradientBrush>

    <!-- Amber (scanning / connecting) -->
    <Color x:Key="AmberColor">#E0B071</Color>
    <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource AmberColor}" />

    <Color x:Key="AmberTintColor">#F8E9D2</Color>
    <SolidColorBrush x:Key="AmberTintBrush" Color="{StaticResource AmberTintColor}" />

    <!-- Titlebar -->
    <Color x:Key="TitlebarColor">#F7ECE7</Color>
    <SolidColorBrush x:Key="TitlebarBrush" Color="{StaticResource TitlebarColor}" />

    <!-- Window button hover -->
    <SolidColorBrush x:Key="WinButtonHoverBrush" Color="#0C000000" />

    <!-- Stop button -->
    <Color x:Key="StopButtonColor">#3D2A2A</Color>
    <SolidColorBrush x:Key="StopButtonBrush" Color="{StaticResource StopButtonColor}" />

    <Color x:Key="StopButtonHoverColor">#4D3636</Color>
    <SolidColorBrush x:Key="StopButtonHoverBrush" Color="{StaticResource StopButtonHoverColor}" />

    <SolidColorBrush x:Key="StopButtonDisabledBrush" Color="#E4D7D2" />
    <SolidColorBrush x:Key="StopButtonDisabledForegroundBrush" Color="#B6A7A4" />

    <!-- Disabled -->
    <SolidColorBrush x:Key="DisabledBrush" Color="#EEE3DF" />

    <!-- Kbd (keyboard hint) -->
    <SolidColorBrush x:Key="KbdBrush" Color="#FFFFFF" />

    <!-- Logo gradient stops -->
    <Color x:Key="LogoGradientStart">#C4768A</Color>
    <Color x:Key="LogoGradientMid">#E0A07F</Color>
    <Color x:Key="LogoGradientEnd">#D4A96A</Color>

    <!-- Modal overlay scrim (design overlay-back token: rgba(40,25,25,0.4)) -->
    <Color x:Key="OverlayBackColor">#66281919</Color>
    <SolidColorBrush x:Key="OverlayBackBrush" Color="{StaticResource OverlayBackColor}" />

    <!-- Shadow -->
    <Color x:Key="CardShadowColor">#0F4E2828</Color>
    <Color x:Key="PopoverShadowColor">#294E2828</Color>
    <system:Double x:Key="CardShadowOpacity">0.1</system:Double>

    <!-- Subtle brand watermark sitting behind card-frame content (design .frame-watermark). -->
    <system:Double x:Key="FrameWatermarkOpacity">0.08</system:Double>

</ResourceDictionary>
