<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== TYPOGRAPHY ==================== -->

    <Style x:Key="HeaderText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SubHeaderText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="19" />
    </Style>

    <Style x:Key="LabelText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
        <!-- Letter spacing via font rendering -->

    </Style>

    <Style x:Key="FaintText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
    </Style>

    <!-- ==================== PRIMARY BUTTON ==================== -->

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="{DynamicResource RoseBrush}"
                            CornerRadius="9"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RoseHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource DisabledBrush}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource TextFaintBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButtonLarge" BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
        <Setter Property="Height" Value="46" />
        <Setter Property="Padding" Value="22,0" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- ==================== GHOST BUTTON ==================== -->

    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderStrongBrush}"
                            BorderThickness="1"
                            CornerRadius="9"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource SurfaceSoftBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== STOP BUTTON ==================== -->

    <Style x:Key="StopButton" TargetType="Button">
        <Setter Property="Height" Value="52" />
        <Setter Property="Padding" Value="28,0" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- Shadow layers: empty blurred siblings so the label/icon stay sharp
                             (WPF shadow rule). Direction=270 = straight down to match the design's
                             CSS `0 4px 14px` offset. The black shadow shows normally and crossfades
                             to the sage-tinted shadow while flashing; the opaque content Borders below
                             cover their bodies, leaving only the blurred halo visible. -->
                        <Border x:Name="ShadowLayer"
                                Background="{DynamicResource StopButtonBrush}"
                                CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="4" Direction="270" BlurRadius="14"
                                                  Color="Black" Opacity="0.28" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="SageShadowLayer"
                                Background="{DynamicResource SageBrush}"
                                CornerRadius="12"
                                Opacity="0"
                                IsHitTestVisible="False">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="4" Direction="270" BlurRadius="14"
                                                  Color="#7FA688" Opacity="0.4" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="Bg"
                                Background="{DynamicResource StopButtonBrush}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True" />
                        <Border x:Name="FlashBg"
                                Background="{DynamicResource SageBrush}"
                                CornerRadius="12"
                                Opacity="0"
                                IsHitTestVisible="False"
                                SnapsToDevicePixels="True" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="{TemplateBinding Padding}">
                            <!-- Stop icon (filled square) -->
                            <Border Width="14" Height="14" CornerRadius="2"
                                    Background="White" Margin="0,0,10,0" />
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource StopButtonHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource StopButtonDisabledBrush}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource StopButtonDisabledForegroundBrush}" />
                            <!-- Design: disabled stop button has `box-shadow: none`. -->
                            <Setter TargetName="ShadowLayer" Property="Opacity" Value="0" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsStopFlashing}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FlashBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.16" />
                                        <!-- Crossfade the halo black → sage to mirror `.btn.stop.flashed`. -->
                                        <DoubleAnimation Storyboard.TargetName="ShadowLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.16" />
                                        <DoubleAnimation Storyboard.TargetName="SageShadowLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FlashBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.4" />
                                        <DoubleAnimation Storyboard.TargetName="ShadowLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.4" />
                                        <DoubleAnimation Storyboard.TargetName="SageShadowLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.4" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== MODE TAB (RadioButton styled as pill) ==================== -->

    <Style x:Key="ModeTab" TargetType="RadioButton">
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bg"
                            Background="Transparent"
                            CornerRadius="17"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource TextBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RoseBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource TextFaintBrush}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== SETTINGS: SEGMENTED CONTROL (theme) ==================== -->
    <!-- RadioButtons styled as pills inside a rounded track (see SettingsView). The active
         pill fills rose with white content; the icon Path binds to the control Foreground so
         it recolours to white alongside the label. (The design's subtle active-pill glow is
         omitted: a DropShadowEffect on a text-bearing element blurs the text — see the WPF
         shadow rule in CLAUDE.md.) -->
    <Style x:Key="SegButton" TargetType="RadioButton">
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <!-- Explicit half-height radius (height 30 ⇒ 15) gives a clean capsule,
                         matching the ModeTab pill; an over-large value can render oval. -->
                    <Border x:Name="Bg" Background="Transparent" CornerRadius="15"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RoseBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== SETTINGS: KO-FI BUTTON ==================== -->
    <!-- Fixed brand colours (#FF5E5B), not theme tokens. Two-layer shadow (empty sibling
         Border carries the DropShadow) so the label/icon stay sharp per the WPF shadow rule. -->
    <Style x:Key="KofiButton" TargetType="Button">
        <Setter Property="Height" Value="46" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- Shadow layer: empty, blurred -->
                        <Border CornerRadius="9" Background="#FF5E5B" Margin="0,2,0,0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="4" BlurRadius="14"
                                                  Color="#FF5E5B" Opacity="0.32" />
                            </Border.Effect>
                        </Border>
                        <!-- Content layer: sharp text -->
                        <Border x:Name="Bg" CornerRadius="9" Background="#FF5E5B">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#F5514E" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== SETTINGS: ICON BUTTON (header back, etc.) ==================== -->
    <!-- 34px square, 9px radius — the design's .icon-btn. -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" CornerRadius="9"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource SurfaceSoftBrush}" />
                            <Setter TargetName="Bg" Property="BorderBrush"
                                    Value="{DynamicResource BorderStrongBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== SETTINGS: SMALL BUTTONS (data-folder actions) ==================== -->
    <!-- .btn.sm — h34, sized to content. Ghost (bordered) + subtle (borderless) variants. -->
    <Style x:Key="GhostButtonSmall" BasedOn="{StaticResource GhostButton}" TargetType="Button">
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FontSize" Value="12.5" />
    </Style>

    <!-- .btn.subtle.sm — rose-soft fill + rose-dark content, hover rose-tint. -->
    <Style x:Key="SubtleButtonSmall" TargetType="Button">
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource RoseDarkBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{DynamicResource RoseSoftBrush}" CornerRadius="9"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource RoseTintBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== DEVICE ROW ==================== -->

    <Style x:Key="DeviceRow" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12,12,14,12" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!-- ==================== STEPPER (connection progress) ==================== -->

    <Style x:Key="StepCircle" TargetType="Border">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- ==================== KEYBOARD HINT ==================== -->

    <Style x:Key="KbdHint" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource KbdBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="7,2" />
    </Style>

    <!-- ==================== MANUAL SPEED SLIDER ==================== -->

    <Style x:Key="SliderRepeatButtonFilled" TargetType="RepeatButton">
        <Setter Property="Height" Value="8" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="{DynamicResource RoseBrush}"
                            CornerRadius="4,0,0,4" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SliderRepeatButtonEmpty" TargetType="RepeatButton">
        <Setter Property="Height" Value="8" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="{DynamicResource AppBorderBrush}"
                            CornerRadius="0,4,4,0" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SliderThumbStyle" TargetType="Thumb">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <!-- Shadow layer -->
                        <Ellipse Fill="{DynamicResource SliderThumbBrush}">
                            <Ellipse.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="6"
                                                  Color="#4E2828" Opacity="0.35" />
                            </Ellipse.Effect>
                        </Ellipse>
                        <!-- Face layer: light knob in both themes (design uses a white knob). -->
                        <Ellipse x:Name="Face"
                                 Fill="{DynamicResource SliderThumbBrush}"
                                 Stroke="{DynamicResource RoseBrush}"
                                 StrokeThickness="2" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Face" Property="StrokeThickness" Value="2.5" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Face" Property="Fill"
                                    Value="{DynamicResource RoseSoftBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ManualSpeedSlider" TargetType="Slider">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <Track x:Name="PART_Track" Margin="12,0">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SliderRepeatButtonFilled}" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SliderThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SliderRepeatButtonEmpty}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== GOLD ARC PROGRESS BAR ==================== -->

    <Style x:Key="GoldArcBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid x:Name="TemplateRoot">
                        <Border x:Name="PART_Track"
                                CornerRadius="2"
                                Background="{DynamicResource AppBorderBrush}" />
                        <Border x:Name="PART_Indicator"
                                CornerRadius="2"
                                Background="{DynamicResource GoldBrush}"
                                HorizontalAlignment="Left" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== PRESET CHIP ==================== -->

    <Style x:Key="PresetChip" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="16,9"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource RoseSoftBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource RoseBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource RoseTintBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
