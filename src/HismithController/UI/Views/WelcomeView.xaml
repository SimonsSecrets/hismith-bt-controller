<UserControl x:Class="HismithController.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HismithController.ViewModels"
             d:DataContext="{d:DesignInstance vm:MainViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- "STEP 0n" eyebrow (design .welcome .step-card .num) -->
        <Style x:Key="StepNum" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <!-- Step label (design .welcome .step-card .lab) -->
        <Style x:Key="StepLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <!-- Full-window scrim. The control fills the whole window (mounted last in MainWindow),
         so the scrim covers the connection/connected content and the footer. -->
    <Border Background="{DynamicResource OverlayBackBrush}">
        <!-- Centred card, two-layer drop shadow (CLAUDE.md WPF rule — the card holds text). -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
              Width="440" Margin="24">
            <!-- Shadow layer: empty Border, purely for the drop shadow visual. -->
            <Border CornerRadius="16" Background="{DynamicResource SurfaceBrush}">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="6" BlurRadius="30"
                                      Color="{DynamicResource PopoverShadowColor}" Opacity="0.6" />
                </Border.Effect>
            </Border>
            <!-- Content layer: no Effect, text renders sharp. -->
            <Border CornerRadius="16" Background="{DynamicResource SurfaceBrush}" Padding="36">
                <StackPanel>

                    <!-- Gradient logo tile -->
                    <Border Width="56" Height="56" CornerRadius="14"
                            HorizontalAlignment="Center" Margin="0,0,0,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{DynamicResource LogoGradientStart}" Offset="0" />
                                <GradientStop Color="{DynamicResource LogoGradientMid}" Offset="0.6" />
                                <GradientStop Color="{DynamicResource LogoGradientEnd}" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Heading + tagline -->
                    <TextBlock Text="HismithController" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Explore, Experiment, Enjoy" FontSize="13.5"
                               Foreground="{DynamicResource TextDimBrush}"
                               HorizontalAlignment="Center" Margin="0,6,0,22" />

                    <!-- Three numbered step cards -->
                    <UniformGrid Rows="1" Columns="3" Margin="0,0,0,22">
                        <!-- Step 01 — Connect -->
                        <Border CornerRadius="12" Padding="8,14" Margin="0,0,6,0"
                                Background="{DynamicResource SurfaceSoftBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="STEP 01" Style="{StaticResource StepNum}" />
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="White" HorizontalAlignment="Center"
                                        BorderBrush="{DynamicResource RoseTintBrush}" BorderThickness="1"
                                        Margin="0,0,0,8">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M7 7l10 10-5 5V2l5 5L7 17"
                                                  Stroke="{DynamicResource RoseBrush}" StrokeThickness="1.6"
                                                  StrokeLineJoin="Round"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="Connect" Style="{StaticResource StepLabel}" />
                            </StackPanel>
                        </Border>

                        <!-- Step 02 — Choose a mode -->
                        <Border CornerRadius="12" Padding="8,14" Margin="3,0,3,0"
                                Background="{DynamicResource SurfaceSoftBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="STEP 02" Style="{StaticResource StepNum}" />
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="White" HorizontalAlignment="Center"
                                        BorderBrush="{DynamicResource RoseTintBrush}" BorderThickness="1"
                                        Margin="0,0,0,8">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M9 18V5l10-2v13"
                                                  Stroke="{DynamicResource RoseBrush}" StrokeThickness="1.6"
                                                  StrokeLineJoin="Round"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                            <Ellipse Canvas.Left="5" Canvas.Top="16" Width="4" Height="4"
                                                     Stroke="{DynamicResource RoseBrush}" StrokeThickness="1.6" />
                                            <Ellipse Canvas.Left="15" Canvas.Top="14" Width="4" Height="4"
                                                     Stroke="{DynamicResource RoseBrush}" StrokeThickness="1.6" />
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="Choose a mode" Style="{StaticResource StepLabel}" />
                            </StackPanel>
                        </Border>

                        <!-- Step 03 — Play -->
                        <Border CornerRadius="12" Padding="8,14" Margin="6,0,0,0"
                                Background="{DynamicResource SurfaceSoftBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="STEP 03" Style="{StaticResource StepNum}" />
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="White" HorizontalAlignment="Center"
                                        BorderBrush="{DynamicResource RoseTintBrush}" BorderThickness="1"
                                        Margin="0,0,0,8">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M7 4.5v15l13-7.5z"
                                                  Fill="{DynamicResource RoseBrush}" />
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="Play" Style="{StaticResource StepLabel}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Get started. Two-layer so the soft rose glow (design .btn box-shadow
                         0 2px 6px rgba(196,118,138,0.30)) doesn't rasterize-blur the label: the
                         empty rose Border behind casts the glow, the Button paints sharp on top. -->
                    <Grid HorizontalAlignment="Center">
                        <Border CornerRadius="9" Background="{DynamicResource RoseBrush}"
                                Margin="2,4,2,4">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="16"
                                                  Color="{DynamicResource RoseColor}" Opacity="0.45" />
                            </Border.Effect>
                        </Border>
                        <Button Style="{StaticResource PrimaryButtonLarge}" MinWidth="200"
                                Content="Get started"
                                Command="{Binding DismissWelcomeCommand}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
