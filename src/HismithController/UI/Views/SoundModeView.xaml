<UserControl x:Class="HismithController.Views.SoundModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HismithController.ViewModels"
             xmlns:conv="clr-namespace:HismithController.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:SoundModeViewModel}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BinToHeightConverter x:Key="BinToHeight" />
    </UserControl.Resources>

    <StackPanel>

        <!-- ========== HEADER ========== -->
        <TextBlock Text="Sound mode"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" />
        <TextBlock Text="Beats from your system audio drive the device."
                   FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                   Margin="0,2,0,18" />

        <!-- ========== DIAGNOSTIC (remove after fix) ========== -->
        <WrapPanel Margin="0,0,0,4">
            <TextBlock Text="{Binding SpectrumBins[0].Value,  StringFormat='B0:{0:F5} '}"  FontSize="10" Foreground="{DynamicResource TextDimBrush}" />
            <TextBlock Text="{Binding SpectrumBins[14].Value, StringFormat='B14:{0:F5} '}" FontSize="10" Foreground="{DynamicResource TextDimBrush}" />
            <TextBlock Text="{Binding SpectrumBins[28].Value, StringFormat='B28:{0:F5} '}" FontSize="10" Foreground="{DynamicResource TextDimBrush}" />
            <TextBlock Text="{Binding SpectrumBins[42].Value, StringFormat='B42:{0:F5}'}"  FontSize="10" Foreground="{DynamicResource TextDimBrush}" />
        </WrapPanel>

        <!-- ========== VISUALIZER ========== -->
        <Border CornerRadius="8" Height="90" ClipToBounds="True"
                Background="{DynamicResource SurfaceSoftBrush}">
            <Grid>

                <!-- Spectrum bars: 56 centre-anchored columns bound to SpectrumBins.
                     Each bar has VerticalAlignment="Center" so it grows symmetrically
                     from the middle outward (matching the design's transform-origin:50%50%
                     / scaleY pattern). Height is bound on the Border (a FrameworkElement)
                     so WPF's normal property-change path updates it; ScaleTransform.ScaleY
                     lives on a Freezable whose DataContext is populated after template
                     adoption and therefore never receives binding updates. -->
                <ItemsControl ItemsSource="{Binding SpectrumBins}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <!-- Stretch fills the full 90 px cell so ContentPresenter passes
                             the complete cell height to the bar, letting
                             VerticalAlignment="Center" anchor growth at the mid-point. -->
                        <Style TargetType="ContentPresenter">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- VerticalAlignment="Center": bar grows symmetrically up and
                                 down from the container's mid-line as Height increases —
                                 the same visual result as CSS transform-origin:50%50% scaleY.
                                 CornerRadius all-round because the bar can grow in both
                                 directions from center (no bottom-flat edge needed). -->
                            <Border Margin="1.5,0"
                                    Background="{DynamicResource RoseBrush}"
                                    CornerRadius="1.5"
                                    VerticalAlignment="Center"
                                    Height="{Binding Value, Converter={StaticResource BinToHeight}}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Idle overlay: shown when there is no audio signal (HasAudio=false).
                     Covers the bars and prompts the user to play music. -->
                <Grid Visibility="{Binding HasAudio, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                      Background="{DynamicResource SurfaceSoftBrush}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Concentric rings communicate the "listening" / idle state. -->
                        <Grid Width="54" Height="54" HorizontalAlignment="Center">
                            <Ellipse Width="54" Height="54" Fill="Transparent"
                                     Stroke="{DynamicResource AppBorderBrush}" StrokeThickness="1"
                                     Opacity="0.4" />
                            <Ellipse Width="36" Height="36" Fill="Transparent"
                                     Stroke="{DynamicResource AppBorderBrush}" StrokeThickness="1"
                                     Opacity="0.55" />
                            <Ellipse Width="18" Height="18" Fill="Transparent"
                                     Stroke="{DynamicResource AppBorderBrush}" StrokeThickness="1"
                                     Opacity="0.7" />
                        </Grid>
                        <TextBlock Text="Play some music to get started"
                                   FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                                   HorizontalAlignment="Center" Margin="0,10,0,0" />
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>

    </StackPanel>
</UserControl>
