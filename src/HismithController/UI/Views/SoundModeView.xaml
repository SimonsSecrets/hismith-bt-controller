<UserControl x:Class="HismithController.Views.SoundModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HismithController.ViewModels"
             xmlns:ctrl="clr-namespace:HismithController.Controls"
             xmlns:conv="clr-namespace:HismithController.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:SoundModeViewModel}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BinToHeightConverter      x:Key="BinToHeight" />
    </UserControl.Resources>

    <StackPanel>

        <!-- ========== HEADER ========== -->
        <TextBlock Text="Sound mode"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" />
        <TextBlock FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                   Margin="0,2,0,14" TextWrapping="Wrap">
            Beats from your system audio drive the device. This currently works best with metronome-style input sounds.
        </TextBlock>

        <!-- ========== VISUALIZER ========== -->
        <!-- x:Name lets the centered transport button bind to this Border's
             IsMouseOver so the pause control reveals on hover while playing. -->
        <Border x:Name="Visualizer"
                CornerRadius="14" Height="140" ClipToBounds="True"
                Background="{DynamicResource VizBackgroundBrush}">
            <Grid>

                <!-- Spectrum bars: 56 centre-anchored columns bound to SpectrumBins.
                     Each bar has VerticalAlignment="Center" so it grows symmetrically
                     from the middle outward (matching the design's transform-origin:50%50%
                     / scaleY pattern). Height is bound on the Border (a FrameworkElement)
                     so WPF's normal property-change path updates it; ScaleTransform.ScaleY
                     lives on a Freezable whose DataContext is populated after template
                     adoption and therefore never receives binding updates. -->
                <ItemsControl ItemsSource="{Binding SpectrumBins}">
                    <ItemsControl.Style>
                        <!-- Fade the bars while detection is paused (design uses 0.4),
                             with a short transition matching the transport button fade. -->
                        <Style TargetType="ItemsControl">
                            <Setter Property="Opacity" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDrivingDevice}" Value="False">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0.4" Duration="0:0:0.18" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.18" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <!-- Stretch fills the full 140 px cell so ContentPresenter passes
                             the complete cell height to the bar, letting
                             VerticalAlignment="Center" anchor growth at the mid-point. -->
                        <Style TargetType="ContentPresenter">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Vertical rose→peach gradient + ~6 px design radius scaled
                                 to the ~2 px bar width (3 reads as rounded; 6 would render
                                 as a full pill on a bar this thin). -->
                            <Border Margin="1.5,0"
                                    CornerRadius="3"
                                    VerticalAlignment="Center"
                                    Height="{Binding Value, Converter={StaticResource BinToHeight}}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="{DynamicResource RoseColor}" Offset="0" />
                                        <GradientStop Color="#E0A07F" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Beat ring: a full-bleed rounded-rect border flashing around the
                     entire visualizer (design .viz-beat-ring: inset:0, 2px rose, 14px
                     radius). Animated by the code-behind on each BeatPulse event: starts
                     invisible (Opacity=0), flashes to 0.85 and decays to 0. CornerRadius
                     matches the visualizer's 14 px; sits above the bars but below the
                     transport button. -->
                <Border x:Name="BeatRingElement"
                        BorderBrush="{DynamicResource RoseBrush}"
                        BorderThickness="2"
                        CornerRadius="14"
                        Opacity="0"
                        IsHitTestVisible="False" />

                <!-- Detection-paused badge: overlaid at the top-right of the visualizer
                     (matching the design's top:12 / right:14). Shown when device
                     driving is off and there IS audio (idle overlay handles the
                     no-audio case anyway). -->
                <!-- Gold-tinted, borderless pill with #8B6630 text/glyph and SemiBold
                     weight (design .pause-badge: gold-tint bg, color #8B6630, weight 600). -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,12,14,0"
                        Background="{DynamicResource GoldTintBrush}"
                        CornerRadius="10"
                        Padding="10,5"
                        IsHitTestVisible="False"
                        Visibility="{Binding IsDrivingDevice,
                                     Converter={StaticResource BoolToVis},
                                     ConverterParameter=Invert}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Pause glyph: two thin bars -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    Margin="0,0,6,0">
                            <Rectangle Width="2.5" Height="9" RadiusX="1" RadiusY="1"
                                       Fill="#8B6630" />
                            <Rectangle Width="2.5" Height="9" RadiusX="1" RadiusY="1"
                                       Fill="#8B6630"
                                       Margin="3,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="Detection paused"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#8B6630"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Idle prompt: a centered label shown only while device driving is
                     enabled with no audio detected. Gated via a MultiDataTrigger
                     (HasAudio=False AND IsDrivingDevice=True) because Visibility depends
                     on two bound conditions. When off, the centered transport button
                     occupies this space. -->
                <Grid Background="{DynamicResource SurfaceSoftBrush}">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasAudio}" Value="False" />
                                        <Condition Binding="{Binding IsDrivingDevice}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Three bobbing dots above the prompt (design .idle-rings):
                             12 px circles, each looping translateY 0→-4 + opacity
                             0.5→1 over 1.4 s (0.7 s out, AutoReverse back), staggered
                             0 / 0.2 / 0.4 s. Started on Loaded; SineEase gives the CSS
                             ease-in-out feel. Deliberate deviation from the design's
                             rose-tint fill: that token is nearly invisible against our
                             solid soft-surface idle background, so we use the stronger
                             RoseBrush for contrast. -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,0,0,8">
                            <StackPanel.Triggers>
                                <EventTrigger RoutedEvent="StackPanel.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="Dot1"
                                                             Storyboard.TargetProperty="RenderTransform.Y"
                                                             From="0" To="-4" Duration="0:0:0.7" BeginTime="0:0:0">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Dot1"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0.5" To="1" Duration="0:0:0.7" BeginTime="0:0:0">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Dot2"
                                                             Storyboard.TargetProperty="RenderTransform.Y"
                                                             From="0" To="-4" Duration="0:0:0.7" BeginTime="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Dot2"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0.5" To="1" Duration="0:0:0.7" BeginTime="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Dot3"
                                                             Storyboard.TargetProperty="RenderTransform.Y"
                                                             From="0" To="-4" Duration="0:0:0.7" BeginTime="0:0:0.4">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Dot3"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0.5" To="1" Duration="0:0:0.7" BeginTime="0:0:0.4">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </StackPanel.Triggers>
                            <Ellipse x:Name="Dot1" Width="12" Height="12" Opacity="0.5"
                                     Fill="{DynamicResource RoseBrush}" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="Dot2" Width="12" Height="12" Opacity="0.5" Margin="6,0,0,0"
                                     Fill="{DynamicResource RoseBrush}" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="Dot3" Width="12" Height="12" Opacity="0.5" Margin="6,0,0,0"
                                     Fill="{DynamicResource RoseBrush}" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </StackPanel>
                        <TextBlock Text="Play some music to get started"
                                   FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- Centered transport button — overlaid on top of everything.
                     Paused: solid gold play button, always visible (reads as "resume").
                     Playing: rose pause button, hidden until the visualizer is hovered.
                     Last child in the Grid so it renders above the bars/idle overlay. -->
                <Button x:Name="TransportButton"
                        Width="60" Height="60"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Command="{Binding ToggleDrivingDeviceCommand}"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <!-- Shown state is the default; the trigger below hides it
                                 only while playing AND the visualizer is not hovered. -->
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="IsHitTestVisible" Value="True" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsDrivingDevice}" Value="True" />
                                        <Condition Binding="{Binding IsMouseOver, ElementName=Visualizer}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="IsHitTestVisible" Value="False" />
                                    <!-- Fade matches the design's 180 ms opacity transition. -->
                                    <MultiDataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.18" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </MultiDataTrigger.EnterActions>
                                    <MultiDataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.18" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </MultiDataTrigger.ExitActions>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <!-- Shadow layer: empty sibling so the drop shadow never
                                 rasterizes the icon (per the two-layer shadow rule). -->
                            <Grid>
                                <Border CornerRadius="30"
                                        Background="{DynamicResource RoseBrush}">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="3" BlurRadius="20"
                                                          Color="#C4768A" Opacity="0.45" />
                                    </Border.Effect>
                                </Border>
                                <Border x:Name="Bg"
                                        CornerRadius="30"
                                        Background="{DynamicResource RoseBrush}"
                                        SnapsToDevicePixels="True">
                                    <Grid Width="60" Height="60">
                                        <!-- Pause icon: shown while playing -->
                                        <StackPanel x:Name="PauseIcon"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Rectangle Width="4.5" Height="18"
                                                       Fill="White"
                                                       RadiusX="2" RadiusY="2" />
                                            <Rectangle Width="4.5" Height="18"
                                                       Fill="White"
                                                       RadiusX="2" RadiusY="2"
                                                       Margin="5,0,0,0" />
                                        </StackPanel>
                                        <!-- Play icon: shown while paused -->
                                        <Path x:Name="PlayIcon"
                                              Data="M 0,0 L 19,11.5 L 0,23 Z"
                                              Fill="White"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="3,0,0,0"
                                              Visibility="Collapsed" />
                                    </Grid>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <!-- Paused state: gold background + play icon -->
                                <DataTrigger Binding="{Binding IsDrivingDevice}" Value="False">
                                    <Setter TargetName="Bg"        Property="Background"
                                            Value="{DynamicResource GoldBrush}" />
                                    <Setter TargetName="PauseIcon" Property="Visibility"
                                            Value="Collapsed" />
                                    <Setter TargetName="PlayIcon"  Property="Visibility"
                                            Value="Visible" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.88" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.74" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>
        </Border>

        <!-- ========== LIVE STATS BAR ========== -->
        <!-- Spans the full container width directly below the visualizer.
             Music shows the detected tempo; Device/Speed show the post-ratio output
             (0 while not actively driving). The "÷N" rhythm badge is overlaid centered
             on the Music↔Device boundary — see the overlay Grid after the stats. -->
        <Grid Margin="0,14,0,0">
            <Border CornerRadius="12"
                    Background="{DynamicResource SurfaceSoftBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    Padding="0,9">
                <Grid>
                <UniformGrid Rows="1" Columns="3">

                    <!-- Music stat -->
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Hair spaces (U+200A) between letters approximate the design's
                             letter-spacing: 0.08em — WPF TextBlock has no letter-spacing /
                             CharacterSpacing property, so tracking is faked with thin glyphs. -->
                        <TextBlock Text="M&#x200A;U&#x200A;S&#x200A;I&#x200A;C"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,3,0,0">
                            <!-- Music BPM tracks detection, which runs continuously —
                                 show it whenever audio is present, independent of play
                                 state. Play only gates driving the device (Device/Speed). -->
                            <TextBlock Text="{Binding LiveBpm}"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       Visibility="{Binding HasAudio,
                                                    Converter={StaticResource BoolToVis}}" />
                            <!-- No audio: show a dash -->
                            <TextBlock Text="—"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       Visibility="{Binding HasAudio,
                                                    Converter={StaticResource BoolToVis},
                                                    ConverterParameter=Invert}" />
                            <TextBlock Text=" bpm"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       VerticalAlignment="Bottom"
                                       Margin="1,0,0,2" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Device stat: post-ratio device BPM. DeviceBpm returns 0 while
                         not actively driving (paused / silent), matching the design. -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="D&#x200A;E&#x200A;V&#x200A;I&#x200A;C&#x200A;E"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,3,0,0">
                            <TextBlock Text="{Binding DeviceBpm}"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" />
                            <TextBlock Text=" bpm"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       VerticalAlignment="Bottom"
                                       Margin="1,0,0,2" />
                            <!-- Gold "Capped" badge: shown only when the cap is actively
                                 limiting the post-ratio output (design's gold capActive pill). -->
                            <Border Background="{DynamicResource GoldTintBrush}"
                                    CornerRadius="8"
                                    Padding="6,1"
                                    VerticalAlignment="Center"
                                    Margin="6,0,0,0"
                                    Visibility="{Binding IsCapActive,
                                                 Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Capped"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#8B6630" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Speed stat: device BPM as a % of the 240 full-scale (design's
                         fixed reference). DeviceSpeedPercent returns 0 while not driving. -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="S&#x200A;P&#x200A;E&#x200A;E&#x200A;D"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,3,0,0">
                            <TextBlock Text="{Binding DeviceSpeedPercent}"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" />
                            <TextBlock Text=" %"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       VerticalAlignment="Bottom"
                                       Margin="1,0,0,2" />
                        </StackPanel>
                    </StackPanel>

                </UniformGrid>

                    <!-- "÷N" rhythm badge. Overlaid on a 3-column grid matching the
                         stats layout: Column 0 + ColumnSpan 2 centered puts it at the
                         1/3 mark — exactly the Music↔Device boundary. Visible whenever a
                         non-1 rhythm is selected, regardless of driving state. -->
                    <Grid IsHitTestVisible="False"
                          Visibility="{Binding IsRatioBadgeVisible,
                                       Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Grid.ColumnSpan="2"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="{DynamicResource RoseSoftBrush}"
                                CornerRadius="8"
                                Padding="6,1">
                            <TextBlock Text="{Binding RatioBadgeText}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource RoseDarkBrush}" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

        </Grid>

        <!-- ========== THRUST RHYTHM SELECTOR ========== -->
        <!-- Header row: title (left) + muted hint (right). -->
        <Grid Margin="0,18,0,8">
            <!-- Design .label: uppercase, text-dim, weight 600, letter-spacing 0.04em
                 (tracking faked with hair spaces — WPF has no letter-spacing). -->
            <TextBlock Text="THRUST RHYTHM"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextDimBrush}"
                       HorizontalAlignment="Left" VerticalAlignment="Center" />
            <TextBlock Text="How many beats per stroke"
                       FontSize="11"
                       Foreground="{DynamicResource TextDimBrush}"
                       HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>

        <!-- Three tiles in a 3-col grid. Each tile is a Button (Command-driven, like
             the design's onClick) whose active highlight tracks ThrustRhythmOption.IsSelected. -->
        <ItemsControl ItemsSource="{Binding RhythmOptions}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" Columns="3" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Margin="4,0"
                            Cursor="Hand"
                            Command="{Binding DataContext.SelectRhythmCommand,
                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Tile"
                                        CornerRadius="12"
                                        BorderThickness="1.5"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        Background="{DynamicResource SurfaceSoftBrush}"
                                        Padding="10,12,10,10">
                                    <StackPanel>
                                        <!-- Diagram: text-dim normally, rose when active.
                                             The shapes inside follow this Foreground. -->
                                        <ctrl:RhythmDiagram x:Name="Diag"
                                                            Height="32"
                                                            Ratio="{Binding Ratio}"
                                                            Foreground="{DynamicResource TextDimBrush}" />
                                        <TextBlock x:Name="Lab"
                                                   Text="{Binding Label}"
                                                   FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="10.5" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- Hover: rose border + rose-soft fill (design .rhythm-tile:hover). -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Tile" Property="BorderBrush"
                                                Value="{DynamicResource RoseBrush}" />
                                        <Setter TargetName="Tile" Property="Background"
                                                Value="{DynamicResource RoseSoftBrush}" />
                                    </Trigger>
                                    <!-- Active: rose border + rose-soft fill, rose diagram,
                                         rose-dark label (design .rhythm-tile.active). -->
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter TargetName="Tile" Property="BorderBrush"
                                                Value="{DynamicResource RoseBrush}" />
                                        <Setter TargetName="Tile" Property="Background"
                                                Value="{DynamicResource RoseSoftBrush}" />
                                        <Setter TargetName="Diag" Property="Foreground"
                                                Value="{DynamicResource RoseBrush}" />
                                        <Setter TargetName="Lab" Property="Foreground"
                                                Value="{DynamicResource RoseDarkBrush}" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ========== MAX DEVICE SPEED ========== -->
        <!-- Header row: title (left) + "{MaxBpm} BPM · {MaxBpmPercent}%" readout and a
             "Capped" pill (right) shown whenever a cap is set (MaxBpm < 240). -->
        <Grid Margin="0,20,0,10">
            <!-- Design .label: uppercase, text-dim, weight 600, letter-spacing 0.04em. -->
            <TextBlock Text="MAX DEVICE SPEED"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextDimBrush}"
                       HorizontalAlignment="Left" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock FontSize="13" FontWeight="Medium"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center">
                    <Run Text="{Binding MaxBpm}" /><Run Text=" BPM · " /><Run Text="{Binding MaxBpmPercent}" /><Run Text="%" />
                </TextBlock>
                <Border Background="{DynamicResource GoldTintBrush}"
                        CornerRadius="8"
                        Padding="6,1"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        Visibility="{Binding IsCapped,
                                     Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Capped"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#8B6630" />
                </Border>
            </StackPanel>
        </Grid>

        <Slider Minimum="0" Maximum="240"
                Value="{Binding MaxBpm, Mode=TwoWay}"
                Style="{StaticResource ManualSpeedSlider}"
                IsMoveToPointEnabled="True"
                Height="28" />

        <!-- Footer scale labels (design: 0 · 120 · 240 (uncapped)). -->
        <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="0"
                       FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                       HorizontalAlignment="Left" />
            <TextBlock Grid.Column="1" Text="120"
                       FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="240 (uncapped)"
                       FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                       HorizontalAlignment="Right" />
        </Grid>

    </StackPanel>
</UserControl>
