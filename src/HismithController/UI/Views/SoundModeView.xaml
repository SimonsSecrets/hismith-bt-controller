<UserControl x:Class="HismithController.Views.SoundModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HismithController.ViewModels"
             xmlns:conv="clr-namespace:HismithController.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:SoundModeViewModel}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BinToHeightConverter      x:Key="BinToHeight" />
    </UserControl.Resources>

    <StackPanel>

        <!-- ========== HEADER ========== -->
        <TextBlock Text="Sound mode"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" />
        <TextBlock Text="Beats from your system audio drive the device."
                   FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                   Margin="0,2,0,14" />

        <!-- ========== VISUALIZER ========== -->
        <Border CornerRadius="8" Height="90" ClipToBounds="True"
                Background="{DynamicResource SurfaceSoftBrush}">
            <Grid>

                <!-- Spectrum bars: 56 centre-anchored columns bound to SpectrumBins.
                     Each bar has VerticalAlignment="Center" so it grows symmetrically
                     from the middle outward (matching the design's transform-origin:50%50%
                     / scaleY pattern). Height is bound on the Border (a FrameworkElement)
                     so WPF's normal property-change path updates it; ScaleTransform.ScaleY
                     lives on a Freezable whose DataContext is populated after template
                     adoption and therefore never receives binding updates. -->
                <ItemsControl ItemsSource="{Binding SpectrumBins}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <!-- Stretch fills the full 90 px cell so ContentPresenter passes
                             the complete cell height to the bar, letting
                             VerticalAlignment="Center" anchor growth at the mid-point. -->
                        <Style TargetType="ContentPresenter">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="1.5,0"
                                    Background="{DynamicResource RoseBrush}"
                                    CornerRadius="1.5"
                                    VerticalAlignment="Center"
                                    Height="{Binding Value, Converter={StaticResource BinToHeight}}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Beat ring: centred over the visualizer, animated by the code-behind
                     on each BeatPulse event. Starts invisible (Opacity=0); BeginAnimation
                     flashes it to 0.75 and decays to 0 while the ScaleTransform expands
                     from 0.7× to 1.4×. RenderTransformOrigin="0.5,0.5" makes the ring
                     grow outward symmetrically without translating. -->
                <Ellipse x:Name="BeatRingElement"
                         Width="68" Height="68"
                         Stroke="{DynamicResource RoseBrush}"
                         StrokeThickness="2"
                         Fill="Transparent"
                         Opacity="0"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         IsHitTestVisible="False"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Detection-paused badge: overlaid at the bottom of the visualizer.
                     Shown when IsPlaying=false and there IS audio (idle overlay handles
                     the no-audio case and covers this badge anyway). -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,8"
                        Background="{DynamicResource SurfaceSoftBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10,4"
                        IsHitTestVisible="False"
                        Visibility="{Binding IsPlaying,
                                     Converter={StaticResource BoolToVis},
                                     ConverterParameter=Invert}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Pause glyph: two thin bars -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    Margin="0,0,6,0">
                            <Rectangle Width="2.5" Height="9" RadiusX="1" RadiusY="1"
                                       Fill="{DynamicResource TextDimBrush}" />
                            <Rectangle Width="2.5" Height="9" RadiusX="1" RadiusY="1"
                                       Fill="{DynamicResource TextDimBrush}"
                                       Margin="3,0,0,0" />
                        </StackPanel>
                        <TextBlock Text="Detection paused"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Idle overlay: shown when there is no audio signal (HasAudio=false).
                     Covers the bars, beat ring, and pause badge to prompt the user. -->
                <Grid Visibility="{Binding HasAudio,
                                   Converter={StaticResource BoolToVis},
                                   ConverterParameter=Invert}"
                      Background="{DynamicResource SurfaceSoftBrush}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Concentric rings communicate the "listening" / idle state. -->
                        <Grid Width="54" Height="54" HorizontalAlignment="Center">
                            <Ellipse Width="54" Height="54" Fill="Transparent"
                                     Stroke="{DynamicResource AppBorderBrush}" StrokeThickness="1"
                                     Opacity="0.4" />
                            <Ellipse Width="36" Height="36" Fill="Transparent"
                                     Stroke="{DynamicResource AppBorderBrush}" StrokeThickness="1"
                                     Opacity="0.55" />
                            <Ellipse Width="18" Height="18" Fill="Transparent"
                                     Stroke="{DynamicResource AppBorderBrush}" StrokeThickness="1"
                                     Opacity="0.7" />
                        </Grid>
                        <TextBlock Text="Play some music to get started"
                                   FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                                   HorizontalAlignment="Center" Margin="0,10,0,0" />
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>

        <!-- ========== PLAY / PAUSE  +  LIVE STATS BAR ========== -->
        <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40" />   <!-- Play/pause button -->
                <ColumnDefinition Width="12" />   <!-- Gap -->
                <ColumnDefinition Width="*"  />   <!-- Stats bar -->
            </Grid.ColumnDefinitions>

            <!-- Play / pause button — circular, 40×40.
                 Shows a pause icon (two bars, white on rose) when playing, and a
                 play icon (triangle, rose on soft-rose) when paused.
                 DataTriggers swap both the icon visibility and the background. -->
            <Button Grid.Column="0"
                    Width="40" Height="40"
                    Command="{Binding TogglePlayingCommand}"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                CornerRadius="20"
                                Background="{DynamicResource RoseBrush}"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <Grid Width="40" Height="40">
                                <!-- Pause icon: shown while playing -->
                                <StackPanel x:Name="PauseIcon"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Rectangle Width="3.5" Height="12"
                                               Fill="White"
                                               RadiusX="1.5" RadiusY="1.5" />
                                    <Rectangle Width="3.5" Height="12"
                                               Fill="White"
                                               RadiusX="1.5" RadiusY="1.5"
                                               Margin="4,0,0,0" />
                                </StackPanel>
                                <!-- Play icon: shown while paused -->
                                <Path x:Name="PlayIcon"
                                      Data="M 2,0 L 13,6.5 L 2,13 Z"
                                      Fill="{DynamicResource RoseBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="2,0,0,0"
                                      Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Paused state: soft background + rose play icon -->
                            <DataTrigger Binding="{Binding IsPlaying}" Value="False">
                                <Setter TargetName="Bg"       Property="Background"
                                        Value="{DynamicResource RoseSoftBrush}" />
                                <Setter TargetName="Bg"       Property="BorderBrush"
                                        Value="{DynamicResource RoseBrush}" />
                                <Setter TargetName="Bg"       Property="BorderThickness"
                                        Value="1.5" />
                                <Setter TargetName="PauseIcon" Property="Visibility"
                                        Value="Collapsed" />
                                <Setter TargetName="PlayIcon"  Property="Visibility"
                                        Value="Visible" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.68" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Live stats bar: three equal-width stats side by side.
                 Device and Speed columns show "—" in Phase 2; they will be
                 populated when the device-driving path is wired in Phase 3. -->
            <Border Grid.Column="2"
                    CornerRadius="8"
                    Background="{DynamicResource SurfaceSoftBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    Padding="0,9">
                <UniformGrid Rows="1" Columns="3">

                    <!-- Music stat -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="MUSIC"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,3,0,0">
                            <!-- Live: show the BPM integer -->
                            <TextBlock Text="{Binding LiveBpm}"
                                       FontSize="17" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       Visibility="{Binding HasLiveStats,
                                                    Converter={StaticResource BoolToVis}}" />
                            <!-- Not live: show a dash -->
                            <TextBlock Text="—"
                                       FontSize="17" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       Visibility="{Binding HasLiveStats,
                                                    Converter={StaticResource BoolToVis},
                                                    ConverterParameter=Invert}" />
                            <TextBlock Text=" bpm"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       VerticalAlignment="Bottom"
                                       Margin="1,0,0,2" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Device stat (Phase 2 stub: always "—") -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="DEVICE"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,3,0,0">
                            <TextBlock Text="—"
                                       FontSize="17" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDimBrush}" />
                            <TextBlock Text=" bpm"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       VerticalAlignment="Bottom"
                                       Margin="1,0,0,2" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Speed stat (Phase 2 stub: always "—") -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="SPEED"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,3,0,0">
                            <TextBlock Text="—"
                                       FontSize="17" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextDimBrush}" />
                            <TextBlock Text=" %"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       VerticalAlignment="Bottom"
                                       Margin="1,0,0,2" />
                        </StackPanel>
                    </StackPanel>

                </UniformGrid>
            </Border>

        </Grid>

    </StackPanel>
</UserControl>
