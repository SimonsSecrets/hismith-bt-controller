<UserControl x:Class="HismithController.Views.DemoNoticeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HismithController.ViewModels"
             d:DataContext="{d:DesignInstance vm:MainViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Full-window scrim (design .overlay-back). Mounted in MainWindow so it covers the
         connection/connected content and footer; the window content behind is blurred by
         MainWindow's IsDemoNoticeOpen trigger. -->
    <Border Background="{DynamicResource OverlayBackBrush}">
        <!-- Centred dialog card, two-layer drop shadow (CLAUDE.md WPF rule — the card holds text). -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
              Width="400" Margin="24">
            <!-- Shadow layer -->
            <Border CornerRadius="16" Background="{DynamicResource SurfaceBrush}">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="6" BlurRadius="30"
                                      Color="{DynamicResource PopoverShadowColor}" Opacity="0.6" />
                </Border.Effect>
            </Border>
            <!-- Content layer -->
            <Border CornerRadius="16" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                    Padding="26,26,26,22">
                <StackPanel>
                    <!-- Amber warn illustration (design .dlg-illus) -->
                    <Grid Width="56" Height="56" Margin="0,0,0,14" HorizontalAlignment="Center">
                        <Ellipse Fill="{DynamicResource AmberTintBrush}" />
                        <Path Data="M12 4 L22 20 H2 Z M12 10 V15 M12 18 V18.5"
                              Stroke="{DynamicResource AmberBrush}" StrokeThickness="1.5"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="26" Height="26" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock Text="Continue without a device?" Style="{StaticResource HeaderText}"
                               HorizontalAlignment="Center" />

                    <!-- Runs carry their own spacing: WPF collapses the whitespace/newlines
                         around inline <Run> elements, which would drop the space before/after the bold run. -->
                    <TextBlock Style="{StaticResource BodyText}"
                               TextAlignment="Center" Margin="0,8,0,20" TextWrapping="Wrap"><Run Text="You can explore every mode and screen in the app, but it " /><Run FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Text="won't send any signals to a physical device" /><Run Text=". You can connect a device at any time." /></TextBlock>

                    <!-- Actions (design .dlg-actions): equal-width Back / Continue anyway -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource GhostButton}"
                                Content="Back" Height="42"
                                Command="{Binding CancelDemoNoticeCommand}" />
                        <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                                Content="Continue anyway" Height="42"
                                Command="{Binding ConfirmDemoModeCommand}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
