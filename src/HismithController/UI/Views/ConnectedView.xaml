<UserControl x:Class="HismithController.Views.ConnectedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HismithController.ViewModels"
             xmlns:views="clr-namespace:HismithController.Views"
             xmlns:ctrl="clr-namespace:HismithController.Controls"
             xmlns:conv="clr-namespace:HismithController.Converters"
             d:DataContext="{d:DesignInstance vm:MainViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringEqualConverter x:Key="StringEqualConverter" />
        <DataTemplate DataType="{x:Type vm:ManualModeViewModel}">
            <views:ManualModeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SoundModeViewModel}">
            <views:SoundModeView />
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <!-- ==================== FOOTER ==================== -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0"
                Background="{DynamicResource BackgroundBrush}"
                Padding="28,14">
            <DockPanel>
                <!-- Stop button -->
                <Button x:Name="StopBtn" DockPanel.Dock="Left"
                        Style="{StaticResource StopButton}"
                        Command="{Binding EmergencyStopCommand}">
                    <TextBlock x:Name="StopText">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Stop" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStopFlashing}" Value="True">
                                        <Setter Property="Text" Value="Stopped" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <!-- Keyboard hint -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Border Style="{StaticResource KbdHint}">
                        <TextBlock Text="Space" FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}" />
                    </Border>
                    <TextBlock Text=" emergency stop" FontSize="12"
                               Foreground="{DynamicResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ==================== MAIN CONTENT ==================== -->
        <Grid Margin="20,24,20,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ========== LOST-CONNECTION BANNER (UIDeviations §3.1) ========== -->
            <!-- Coral banner shown above the mode content when the BLE link drops (design app.jsx
                 LostBanner / index.html .banner). Dismiss is intentionally omitted: Reconnect is the
                 only action and returns to the pre-connect scan screen. -->
            <Border Grid.Row="0" Margin="0,0,0,16"
                    Visibility="{Binding IsConnectionLost, Converter={StaticResource BoolToVis}}"
                    Background="{DynamicResource CoralTintBrush}"
                    BorderBrush="#ECC1B5" BorderThickness="1"
                    CornerRadius="12" Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Warn badge: white circle + coral warn triangle -->
                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                            Background="White" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Path Data="M12 4 L22 20 H2 Z M12 10 V15 M12 18 V18.5"
                              Stroke="{DynamicResource CoralBrush}" StrokeThickness="1.5"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="16" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <!-- Message -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Connection lost" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#5C2A20" />
                        <TextBlock Text="Your device has stopped. Your settings are preserved."
                                   FontSize="13" Foreground="#7A3A2C" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Action: Reconnect only -->
                    <Button Grid.Column="2" Content="Reconnect"
                            Command="{Binding ReconnectCommand}" Cursor="Hand"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BannerBtn" CornerRadius="8" Padding="14,0"
                                        Height="32" Background="{DynamicResource CoralBrush}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BannerBtn" Property="Background" Value="#C97A6A" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Resources>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="TextElement.Foreground" Value="White" />
                                <Setter Property="TextElement.FontSize" Value="12.5" />
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>

            <!-- ========== MODE BAR ========== -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Settings gear (left) — opens the app-level Settings overlay -->
                <Button Grid.Column="0" HorizontalAlignment="Left"
                        Command="{Binding OpenSettingsCommand}" Cursor="Hand"
                        ToolTip="Settings">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid Width="38" Height="38" Background="Transparent">
                                <!-- Shadow layer -->
                                <Border CornerRadius="999"
                                        Background="{DynamicResource SurfaceBrush}">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" BlurRadius="8"
                                                          Color="{DynamicResource CardShadowColor}" Opacity="{DynamicResource CardShadowOpacity}" />
                                    </Border.Effect>
                                </Border>
                                <!-- Content layer -->
                                <Border x:Name="GearBg" CornerRadius="999"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1">
                                    <Path Data="M12 9 a3 3 0 1 0 0 6 a3 3 0 1 0 0 -6 M19.4 15 a1.7 1.7 0 0 0 .3 1.8 l.1 .1 a2 2 0 1 1 -2.8 2.8 l-.1 -.1 a1.7 1.7 0 0 0 -1.8 -.3 1.7 1.7 0 0 0 -1 1.5 V21 a2 2 0 1 1 -4 0 v-.1 a1.7 1.7 0 0 0 -1 -1.5 1.7 1.7 0 0 0 -1.8 .3 l-.1 .1 a2 2 0 1 1 -2.8 -2.8 l.1 -.1 a1.7 1.7 0 0 0 .3 -1.8 1.7 1.7 0 0 0 -1.5 -1 H3 a2 2 0 1 1 0 -4 h.1 a1.7 1.7 0 0 0 1.5 -1 1.7 1.7 0 0 0 -.3 -1.8 l-.1 -.1 a2 2 0 1 1 2.8 -2.8 l.1 .1 a1.7 1.7 0 0 0 1.8 .3 H9 a1.7 1.7 0 0 0 1 -1.5 V3 a2 2 0 1 1 4 0 v.1 a1.7 1.7 0 0 0 1 1.5 1.7 1.7 0 0 0 1.8 -.3 l.1 -.1 a2 2 0 1 1 2.8 2.8 l-.1 .1 a1.7 1.7 0 0 0 -.3 1.8 V9 a1.7 1.7 0 0 0 1.5 1 H21 a2 2 0 1 1 0 4 h-.1 a1.7 1.7 0 0 0 -1.5 1 z"
                                          Stroke="{DynamicResource TextBrush}" StrokeThickness="1.6"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="17" Height="17" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="GearBg" Property="Background"
                                            Value="{DynamicResource SurfaceSoftBrush}" />
                                    <Setter TargetName="GearBg" Property="BorderBrush"
                                            Value="{DynamicResource BorderStrongBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Mode strip (center) -->
                <Grid Grid.Column="1">
                    <!-- Shadow layer -->
                    <Border CornerRadius="20" Background="{DynamicResource SurfaceBrush}">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="8"
                                              Color="{DynamicResource CardShadowColor}" Opacity="{DynamicResource CardShadowOpacity}" />
                        </Border.Effect>
                    </Border>
                    <!-- Content layer -->
                    <Border CornerRadius="20"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Style="{StaticResource ModeTab}"
                                         IsChecked="{Binding ActiveMode, Converter={StaticResource StringEqualConverter}, ConverterParameter=Manual}"
                                         Command="{Binding SwitchModeCommand}" CommandParameter="Manual">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Gear icon (design "settings"); stroke binds to the tab Foreground
                                         so it turns white alongside the label when the tab is active. -->
                                    <Path Data="M12 9 a3 3 0 1 0 0 6 a3 3 0 1 0 0 -6 M19.4 15 a1.7 1.7 0 0 0 .3 1.8 l.1 .1 a2 2 0 1 1 -2.8 2.8 l-.1 -.1 a1.7 1.7 0 0 0 -1.8 -.3 1.7 1.7 0 0 0 -1 1.5 V21 a2 2 0 1 1 -4 0 v-.1 a1.7 1.7 0 0 0 -1 -1.5 1.7 1.7 0 0 0 -1.8 .3 l-.1 .1 a2 2 0 1 1 -2.8 -2.8 l.1 -.1 a1.7 1.7 0 0 0 .3 -1.8 1.7 1.7 0 0 0 -1.5 -1 H3 a2 2 0 1 1 0 -4 h.1 a1.7 1.7 0 0 0 1.5 -1 1.7 1.7 0 0 0 -.3 -1.8 l-.1 -.1 a2 2 0 1 1 2.8 -2.8 l.1 .1 a1.7 1.7 0 0 0 1.8 .3 H9 a1.7 1.7 0 0 0 1 -1.5 V3 a2 2 0 1 1 4 0 v.1 a1.7 1.7 0 0 0 1 1.5 1.7 1.7 0 0 0 1.8 -.3 l.1 -.1 a2 2 0 1 1 2.8 2.8 l-.1 .1 a1.7 1.7 0 0 0 -.3 1.8 V9 a1.7 1.7 0 0 0 1.5 1 H21 a2 2 0 1 1 0 4 h-.1 a1.7 1.7 0 0 0 -1.5 1 z"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                          StrokeThickness="1.7" Fill="Transparent" StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="14" Height="14" Stretch="Uniform"
                                          VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Manual" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Style="{StaticResource ModeTab}"
                                         IsChecked="{Binding ActiveMode, Converter={StaticResource StringEqualConverter}, ConverterParameter=Sound}"
                                         Command="{Binding SwitchModeCommand}" CommandParameter="Sound">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Music-note icon (design "music"); same Foreground binding for active recolour. -->
                                    <Path Data="M9 18 V5 L19 3 V16 M5 18 a2 2 0 1 0 4 0 a2 2 0 1 0 -4 0 M15 16 a2 2 0 1 0 4 0 a2 2 0 1 0 -4 0"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                          StrokeThickness="1.7" Fill="Transparent" StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Width="14" Height="14" Stretch="Uniform"
                                          VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Sound" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Status chip (right) -->
                <ctrl:StatusChip Grid.Column="2" HorizontalAlignment="Right"
                                 DataContext="{Binding}" />
            </Grid>

            <!-- ========== MODE CONTENT ========== -->
            <Grid Grid.Row="2">
                <!-- Shadow layer -->
                <Border CornerRadius="14" Background="{DynamicResource SurfaceBrush}">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="4" BlurRadius="28"
                                          Color="{DynamicResource CardShadowColor}" Opacity="{DynamicResource CardShadowOpacity}" />
                    </Border.Effect>
                </Border>
                <!-- Content layer -->
                <Border CornerRadius="14" Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                        ClipToBounds="True">
                    <Grid>
                        <Image Style="{StaticResource FrameWatermark}" />
                        <!-- Padding moved onto the content so the watermark can bleed to the frame edge. -->
                        <ScrollViewer Margin="28"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ContentControl Content="{Binding ActiveModeContent}" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
    </DockPanel>
</UserControl>
