<UserControl x:Class="HismithController.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HismithController.ViewModels"
             xmlns:conv="clr-namespace:HismithController.Converters"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:StringEqualConverter x:Key="StringEqualConverter" />

        <!-- Row title / subtitle / value typography (design .rk / .rsub / .rval) -->
        <Style x:Key="RowTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style x:Key="RowSub" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="MaxWidth" Value="280" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,3,0,0" />
        </Style>
        <Style x:Key="RowValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="20,24">

        <!-- ==================== HEADER ==================== -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1"
                Padding="0,0,0,14">
            <StackPanel Orientation="Horizontal">
                <!-- Back arrow → window-level CloseSettingsCommand (DataContext = MainViewModel) -->
                <Button Style="{StaticResource IconButton}"
                        Command="{Binding DataContext.CloseSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        ToolTip="Back">
                    <!-- Viewbox+Canvas preserves the 24x24 viewBox so the arrow keeps the
                         design's proportion (≈18px icon, not a stretched-to-fill glyph). -->
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M19 12 H5 M11 6 l-6 6 6 6"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.8" StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0" />
            </StackPanel>
        </Border>

        <!-- ==================== BODY ==================== -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,20,0,8">
            <StackPanel>

                <!-- ========== APPEARANCE ========== -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="APPEARANCE" Style="{StaticResource LabelText}"
                               Margin="4,0,0,10" />
                    <Grid>
                        <!-- Shadow layer -->
                        <Border CornerRadius="14" Background="{DynamicResource SurfaceBrush}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="14"
                                                  Color="{DynamicResource CardShadowColor}"
                                                  Opacity="{DynamicResource CardShadowOpacity}" />
                            </Border.Effect>
                        </Border>
                        <!-- Content layer -->
                        <Border CornerRadius="14" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                                Padding="18,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Theme" Style="{StaticResource RowTitle}" />
                                    <TextBlock Text="Follow the system setting or pick a fixed look."
                                               Style="{StaticResource RowSub}" />
                                </StackPanel>

                                <!-- Segmented control: Light / Dark / System -->
                                <Border Grid.Column="1" VerticalAlignment="Center"
                                        CornerRadius="18" Padding="3"
                                        Background="{DynamicResource SurfaceSoftBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Style="{StaticResource SegButton}" GroupName="Theme"
                                                     IsChecked="{Binding Theme, Converter={StaticResource StringEqualConverter}, ConverterParameter=Light}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M12 12 m-4 0 a4 4 0 1 0 8 0 a4 4 0 1 0 -8 0 M12 2 V4 M12 20 V22 M4.93 4.93 L6.34 6.34 M17.66 17.66 L19.07 19.07 M2 12 H4 M20 12 H22 M4.93 19.07 L6.34 17.66 M17.66 6.34 L19.07 4.93"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                      StrokeThickness="1.7" StrokeLineJoin="Round"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Width="13" Height="13" Stretch="Uniform"
                                                      VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <TextBlock Text="Light" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton Style="{StaticResource SegButton}" GroupName="Theme"
                                                     IsChecked="{Binding Theme, Converter={StaticResource StringEqualConverter}, ConverterParameter=Dark}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                      StrokeThickness="1.7" Fill="Transparent" StrokeLineJoin="Round"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Width="13" Height="13" Stretch="Uniform"
                                                      VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <TextBlock Text="Dark" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton Style="{StaticResource SegButton}" GroupName="Theme"
                                                     IsChecked="{Binding Theme, Converter={StaticResource StringEqualConverter}, ConverterParameter=System}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M5 4 H19 A2 2 0 0 1 21 6 V15 A2 2 0 0 1 19 17 H5 A2 2 0 0 1 3 15 V6 A2 2 0 0 1 5 4 Z M8 21 H16 M12 17 V21"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                      StrokeThickness="1.7" StrokeLineJoin="Round"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Width="13" Height="13" Stretch="Uniform"
                                                      VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <TextBlock Text="System" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </RadioButton>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- ========== APPLICATION DATA ========== -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="APPLICATION DATA" Style="{StaticResource LabelText}"
                               Margin="4,0,0,10" />
                    <Grid>
                        <!-- Shadow layer -->
                        <Border CornerRadius="14" Background="{DynamicResource SurfaceBrush}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="14"
                                                  Color="{DynamicResource CardShadowColor}"
                                                  Opacity="{DynamicResource CardShadowOpacity}" />
                            </Border.Effect>
                        </Border>
                        <!-- Content layer -->
                        <Border CornerRadius="14" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                                Padding="18,16">
                            <StackPanel>
                                <TextBlock Text="Data folder" Style="{StaticResource RowTitle}" />
                                <TextBlock Text="This folder is used to store your preferences and application log files."
                                           Style="{StaticResource RowSub}" />

                                <!-- Path field: folder icon + ellipsized monospace path -->
                                <Border CornerRadius="10" Padding="13,11" Margin="0,14,0,0"
                                        Background="{DynamicResource SurfaceSoftBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Path Grid.Column="0"
                                              Data="M3 7 a2 2 0 0 1 2 -2 h3.6 a2 2 0 0 1 1.4 .6 L11.4 7 H19 a2 2 0 0 1 2 2 v8 a2 2 0 0 1 -2 2 H5 a2 2 0 0 1 -2 -2 V7 z"
                                              Stroke="{DynamicResource RoseBrush}" StrokeThickness="1.6"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Width="16" Height="16" Stretch="Uniform"
                                              VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding DataFolder}"
                                                   ToolTip="{Binding DataFolder}"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="12" Foreground="{DynamicResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <!-- Actions: Change… + Open in Explorer -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Style="{StaticResource GhostButtonSmall}"
                                            Content="Change…"
                                            Command="{Binding ChangeDataFolderCommand}"
                                            Margin="0,0,8,0" />
                                    <Button Style="{StaticResource SubtleButtonSmall}"
                                            Command="{Binding OpenDataFolderCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M14 4 h6 v6 M20 4 l-8.5 8.5 M18 14 v4 a2 2 0 0 1 -2 2 H6 a2 2 0 0 1 -2 -2 V8 a2 2 0 0 1 2 -2 h4"
                                                  Stroke="{DynamicResource RoseDarkBrush}" StrokeThickness="1.6"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Width="14" Height="14" Stretch="Uniform"
                                                  VerticalAlignment="Center" Margin="0,0,7,0" />
                                            <TextBlock Text="Open in Explorer" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- ========== ABOUT ========== -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="ABOUT" Style="{StaticResource LabelText}"
                               Margin="4,0,0,10" />
                    <Grid>
                        <!-- Shadow layer -->
                        <Border CornerRadius="14" Background="{DynamicResource SurfaceBrush}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="14"
                                                  Color="{DynamicResource CardShadowColor}"
                                                  Opacity="{DynamicResource CardShadowOpacity}" />
                            </Border.Effect>
                        </Border>
                        <!-- Content layer -->
                        <Border CornerRadius="14" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <!-- Version -->
                                <Grid Margin="18,16">
                                    <TextBlock Text="Version" Style="{StaticResource RowTitle}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Version}" Style="{StaticResource RowValue}"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <!-- Author -->
                                <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
                                    <Grid Margin="18,16">
                                        <TextBlock Text="Author" Style="{StaticResource RowTitle}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Author}" Style="{StaticResource RowValue}"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                                <!-- Contact -->
                                <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
                                    <Grid Margin="18,16">
                                        <TextBlock Text="Contact" Style="{StaticResource RowTitle}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontSize="13">
                                            <Hyperlink Command="{Binding OpenContactCommand}"
                                                       Foreground="{DynamicResource RoseDarkBrush}"
                                                       TextDecorations="{x:Null}">
                                                <Run Text="{Binding Contact, Mode=OneWay}" />
                                            </Hyperlink>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- ========== SUPPORT (Ko-fi) ========== -->
                <StackPanel Margin="0,0,0,4">
                    <TextBlock Text="SUPPORT" Style="{StaticResource LabelText}"
                               Margin="4,0,0,10" />
                    <Grid>
                        <!-- Shadow layer -->
                        <Border CornerRadius="14" Background="{DynamicResource SurfaceBrush}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="14"
                                                  Color="{DynamicResource CardShadowColor}"
                                                  Opacity="{DynamicResource CardShadowOpacity}" />
                            </Border.Effect>
                        </Border>
                        <!-- Content layer -->
                        <Border CornerRadius="14" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="Enjoying HismithController?" FontSize="14"
                                           FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="It's built and maintained by one person in their spare time. If you enjoy it, a small tip is much appreciated and keeps it going. ;)"
                                           FontSize="12" Foreground="{DynamicResource TextDimBrush}"
                                           TextWrapping="Wrap" LineHeight="18" Margin="0,6,0,16" />
                                <Button Style="{StaticResource KofiButton}"
                                        Command="{Binding OpenKofiCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M4 8 h13 v4.5 a5 5 0 0 1 -5 5 H9 a5 5 0 0 1 -5 -5 V8 z M17 9 h2.2 a2 2 0 0 1 0 4 H17 M7 2.5 v2 M11 2.5 v2 M15 2.5 v2"
                                              Stroke="White" StrokeThickness="1.8"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Width="18" Height="18" Stretch="Uniform"
                                              VerticalAlignment="Center" Margin="0,0,9,0" />
                                        <TextBlock Text="Support me on Ko-fi" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
